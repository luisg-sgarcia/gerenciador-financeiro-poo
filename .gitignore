# Dependências do Node (Pasta gigante que não deve ir ao Git)
node_modules/

# Pasta de build (Código compilado gerado pelo npx tsc)
dist/
out/

# Logs de erro do NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Variáveis de ambiente e segredos (Senhas, chaves de API)
.env
.env.local

# Arquivos temporários do Sistema Operacional
.DS_Store
Thumbs.db

# Configurações de IDEs (VS Code ou WebStorm)
.vscode/
.idea/

# Arquivos de log e cache do TypeScript
*.tsbuildinfo